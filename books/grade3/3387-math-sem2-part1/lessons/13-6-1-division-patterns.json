  "key_concepts": [
    {
      "concept": "استخدام أنماط القيمة المكانية في القسمة",
      "explanation": "إذا كان 8÷4=2، فإن 80÷4=20 و800÷4=200. النمط: عندما يصبح المقسوم أكبر بـ 10 مرات، يصبح ناتج القسمة أكبر بـ 10 مرات"
    },
    {
      "concept": "القسمة باستخدام حقائق القسمة الأساسية وإضافة الأصفار",
      "explanation": "لإيجاد 800÷4، فكّر في 8÷4=2 ثم أضف صفرين = 200. استخدم الحقيقة الأساسية ثم أضف الأصفار المناسبة"
    }
  ],
  "examples": [
    {
      "problem": "قرر فريق مريم جمع 800 صدفة بحرية من شواطئ الكويت، ووضعها في 4 صناديق. فكم صدفة بحرية سيضع الفريق في كل صندوق؟",
      "solution_steps": [
        "800 ÷ 4 = ؟",
        "استخدم النمط:",
        "8 آحاد ÷ 4 = 2 آحاد → 8 ÷ 4 = 2",
        "8 عشرات ÷ 4 = 2 عشرات → 80 ÷ 4 = 20",
        "8 مئات ÷ 4 = 2 مئات → 800 ÷ 4 = 200"
      ],
      "answer": "سيضع الفريق 200 صدفة بحرية في كل صندوق"
    }
  ],
